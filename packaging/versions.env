# Pinned toolchain for the macOS runtime release pipeline (WEB-4789).
# Sourced by .github/workflows/release-macos-runtime.yml and the scripts in
# packaging/scripts/. Bump deliberately — every value here changes the
# released artifact.

# python.org universal2 framework build (NOT actions/setup-python: that is
# a thin single-arch build and cannot produce universal2 PyInstaller
# bundles). 3.12.10 is the last 3.12.x with a binary installer.
PYTHON_PKG_URL="https://www.python.org/ftp/python/3.12.10/python-3.12.10-macos11.pkg"
PYTHON_PKG_SHA256="8373e58da4ea146b3eb1c1f9834f19a319440b6b679b06050b1f9ee3237aa8e4"
PYTHON_BIN="/Library/Frameworks/Python.framework/Versions/3.12/bin/python3.12"

# Stable identifiers consumed by build-pkg.sh / onboard.sh rendering.
PKG_IDENTIFIER="ai.getunbound.runtime"
INSTALL_PREFIX="/opt/unbound"
DAEMON_LABEL="ai.getunbound.discovery"
